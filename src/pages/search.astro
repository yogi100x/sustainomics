---
export const prerender = false;

import { search } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";

const query = Astro.url.searchParams.get("q")?.trim() || "";

const { items: results } = query
	? await search(query, { collections: ["posts"], limit: 30 })
	: { items: [] };

const fmt = (d: Date | string | null | undefined) => {
	if (!d) return null;
	const date = d instanceof Date ? d : new Date(d as string);
	return isNaN(date.getTime())
		? null
		: date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};
---

<Base
	title={query ? `"${query}" — Search` : "Search — THE SUSTAINOMICS"}
	description="Search THE SUSTAINOMICS news, analysis, and reports."
>
	<div class="srch-wrap">

		{/* ===== HEADER ===== */}
		<header class="srch-head">
			<p class="srch-eyebrow">THE SUSTAINOMICS Search</p>
			<form method="get" action="/search" class="srch-form" role="search">
				<div class="srch-field-wrap">
					<svg class="srch-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
					</svg>
					<input
						type="search"
						name="q"
						value={query}
						placeholder="Search markets, economics, ESG…"
						class="srch-input"
						autofocus
						aria-label="Search query"
					/>
					{query && (
						<a href="/search" class="srch-clear" aria-label="Clear search">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
						</a>
					)}
				</div>
				<button type="submit" class="srch-btn">Search</button>
			</form>
		</header>

		{query && (
			<p class="srch-summary">
				{results.length === 0
					? `No results for "${query}"`
					: `${results.length} result${results.length === 1 ? "" : "s"} for "${query}"`
				}
			</p>
		)}

		{results.length > 0 ? (
			<ol class="srch-results">
				{results.map((result) => (
					<li class="srch-result">
						<a href={`/posts/${result.slug ?? result.id}`} class="sr-link">
							{result.featured_image && (
								<div class="sr-thumb">
									<Image image={result.featured_image} />
								</div>
							)}
							<div class="sr-body">
								<div class="sr-meta">
									{result.collection && <span class="sr-coll">{result.collection}</span>}
									{fmt((result as any).publishedAt) && (
										<span class="sr-date">{fmt((result as any).publishedAt)}</span>
									)}
								</div>
								<h2 class="sr-title">{result.title ?? "Untitled"}</h2>
								{result.snippet && (
									<p class="sr-snippet" set:html={result.snippet} />
								)}
							</div>
						</a>
					</li>
				))}
			</ol>
		) : !query ? (
			<div class="srch-hint">
				<p>Search across THE SUSTAINOMICS news, markets data, ESG reports, and analysis.</p>
				<ul class="srch-topics">
					{["Carbon markets", "ESG investing", "Green bonds", "Net zero", "Climate finance", "Supply chain"].map((t) => (
						<li><a href={`/search?q=${encodeURIComponent(t)}`}>{t}</a></li>
					))}
				</ul>
			</div>
		) : null}
	</div>
</Base>

<style>
	.srch-wrap {
		max-width: 860px;
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6) var(--spacing-20);
	}

	/* Header */
	.srch-head {
		margin-bottom: var(--spacing-8);
		padding-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}
	.srch-eyebrow {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}
	.srch-form {
		display: flex;
		gap: var(--spacing-3);
		align-items: center;
	}
	.srch-field-wrap {
		position: relative;
		flex: 1;
		display: flex;
		align-items: center;
	}
	.srch-icon {
		position: absolute;
		left: var(--spacing-4);
		width: 18px; height: 18px;
		color: var(--color-muted);
		pointer-events: none;
	}
	.srch-input {
		width: 100%;
		padding: var(--spacing-4) var(--spacing-4) var(--spacing-4) 44px;
		font-family: var(--font-sans);
		font-size: var(--font-size-lg);
		border: 2px solid var(--color-border);
		background: var(--color-bg);
		color: var(--color-text);
		border-radius: 0;
		appearance: none;
		-webkit-appearance: none;
	}
	.srch-input:focus {
		outline: none;
		border-color: var(--color-ink);
	}
	.srch-input::placeholder { color: var(--color-muted); }
	.srch-clear {
		position: absolute;
		right: var(--spacing-3);
		width: 20px; height: 20px;
		color: var(--color-muted);
		display: flex; align-items: center; justify-content: center;
	}
	.srch-clear svg { width: 16px; height: 16px; }
	.srch-btn {
		padding: var(--spacing-4) var(--spacing-6);
		background: var(--color-ink);
		color: #fff;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 700;
		border: none;
		border-radius: 0;
		cursor: pointer;
		white-space: nowrap;
		transition: background 0.15s;
	}
	.srch-btn:hover { background: var(--color-accent); }

	/* Summary */
	.srch-summary {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	/* Results */
	.srch-results {
		list-style: none;
		padding: 0; margin: 0;
		display: flex;
		flex-direction: column;
	}
	.srch-result {
		border-bottom: 1px solid var(--color-border-subtle);
	}
	.sr-link {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: var(--spacing-5);
		align-items: start;
		padding: var(--spacing-6) 0;
		text-decoration: none;
		color: inherit;
	}
	.sr-link:has(.sr-thumb) { }
	.sr-link:not(:has(.sr-thumb)) {
		grid-template-columns: 1fr;
	}
	.sr-thumb {
		aspect-ratio: 4/3;
		overflow: hidden;
		background: var(--color-surface);
		flex-shrink: 0;
	}
	.sr-thumb :global(img) {
		width: 100%; height: 100%; object-fit: cover;
		transition: transform 0.3s;
	}
	.sr-link:hover .sr-thumb :global(img) { transform: scale(1.04); }
	.sr-body { display: flex; flex-direction: column; gap: var(--spacing-2); }
	.sr-meta {
		display: flex;
		gap: var(--spacing-3);
		align-items: center;
	}
	.sr-coll {
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-kicker);
	}
	.sr-date {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}
	.sr-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: var(--font-size-xl);
		font-weight: 700;
		line-height: 1.25;
		color: var(--color-ink);
		margin: 0;
		transition: color 0.15s;
	}
	.sr-link:hover .sr-title { color: var(--color-accent); }
	.sr-snippet {
		font-size: var(--font-size-sm);
		line-height: 1.55;
		color: var(--color-text-secondary);
		margin: 0;
	}
	.sr-snippet :global(mark) {
		background: transparent;
		color: var(--color-ink);
		font-weight: 700;
	}

	/* Hint / topics */
	.srch-hint {
		padding: var(--spacing-10) 0;
		color: var(--color-text-secondary);
	}
	.srch-hint p { margin-bottom: var(--spacing-5); }
	.srch-topics {
		list-style: none;
		padding: 0; margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}
	.srch-topics a {
		display: inline-block;
		padding: var(--spacing-2) var(--spacing-4);
		border: 1px solid var(--color-border);
		color: var(--color-text-secondary);
		font-size: var(--font-size-sm);
		font-weight: 500;
		text-decoration: none;
		transition: border-color 0.15s, color 0.15s;
	}
	.srch-topics a:hover {
		border-color: var(--color-ink);
		color: var(--color-ink);
	}

	@media (max-width: 600px) {
		.srch-form { flex-direction: column; align-items: stretch; }
		.srch-btn { width: 100%; text-align: center; }
		.sr-link { grid-template-columns: 80px 1fr; gap: var(--spacing-3); }
	}
</style>
