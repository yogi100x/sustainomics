---
import { getEmDashEntry, getEmDashCollection, decodeSlug } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import AdBlock from "../../components/AdBlock.astro";

const slug = decodeSlug(Astro.params.slug);
if (!slug) return Astro.redirect("/404");

const { entry: article, cacheHint } = await getEmDashEntry("articles", slug);
if (!article) return Astro.redirect("/404");
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Resolve the parent issue from a.data.issue (a magazine ULID).
const issueRef = article.data.issue;
let issue: any = null;
if (issueRef) {
	const { entries: mags } = await getEmDashCollection("magazines").catch(
		() => ({ entries: [] as any[] }),
	);
	issue =
		(mags ?? []).find((m: any) => m.data.id === issueRef || m.id === issueRef) ?? null;
}

const bylines = article.data.bylines ?? [];
const bylineNames =
	bylines.length > 0
		? bylines.map((c: any) => c?.byline?.displayName).filter(Boolean).join(", ")
		: null;

const publishDate =
	(article.data.publishedAt ?? article.data.createdAt)?.toLocaleDateString?.("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;

const section = article.data.mag_section || "Magazine";
---

<Base
	title={article.data.title}
	description={article.data.excerpt}
	type="article"
	content={{ collection: "articles", id: article.data.id, slug }}
>
	<article class="article">
		{
			article.data.featured_image && (
				<div class="article-hero">
					<Image image={article.data.featured_image} />
				</div>
			)
		}

		<div class="article-col">
			{
				issue ? (
					<a class="back" href={`/magazine/${issue.id}`}>
						‹ Back to {issue.data.title}
					</a>
				) : (
					<a class="back" href="/magazine">
						‹ Back to Magazine
					</a>
				)
			}

			<header class="article-header">
				<span class="kick">{section}</span>
				<h1 class="article-title">{article.data.title}</h1>
				{article.data.excerpt && <p class="article-excerpt">{article.data.excerpt}</p>}
				<div class="article-meta">
					{bylineNames && <span class="meta-byline">{bylineNames}</span>}
					{bylineNames && (publishDate || article.data.read_time) && (
						<span class="meta-dot" />
					)}
					{publishDate && <time>{publishDate}</time>}
					{publishDate && article.data.read_time && <span class="meta-dot" />}
					{article.data.read_time && <span>{article.data.read_time}</span>}
				</div>
			</header>

			<AdBlock placement="mid-page" />
			<div class="article-content">
				<PortableText value={article.data.content} />
			</div>

			<footer class="article-foot">
				{
					issue && (
						<a class="foot-link" href={`/magazine/${issue.id}`}>
							‹ Back to {issue.data.title}
						</a>
					)
				}
			</footer>
		</div>
	</article>
</Base>

<style>
	.article {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}
	.article-hero {
		margin: 0 0 var(--spacing-10);
		border-radius: var(--radius-lg, var(--radius));
		overflow: hidden;
		background: var(--color-surface);
		max-height: 460px;
	}
	.article-hero :global(img) {
		width: 100%;
		height: auto;
		max-height: 460px;
		object-fit: cover;
	}
	.article-col {
		max-width: var(--content-width, 720px);
		margin: 0 auto;
	}
	.back {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-muted);
		text-decoration: none;
		margin-bottom: var(--spacing-5);
	}
	.back:hover {
		color: var(--color-text);
	}
	.article-header {
		margin-bottom: var(--spacing-8);
	}
	.kick {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-kicker, var(--color-accent));
	}
	.article-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: clamp(2rem, 4vw, var(--font-size-4xl, 2.75rem));
		font-weight: 700;
		line-height: var(--leading-tight, 1.12);
		margin: var(--spacing-2) 0 var(--spacing-4);
	}
	.article-excerpt {
		font-size: var(--font-size-xl);
		line-height: var(--leading-relaxed, 1.5);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-4);
	}
	.article-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-2) var(--spacing-3);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}
	.meta-byline {
		font-weight: 600;
		color: var(--color-text-secondary);
	}
	.meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}
	.article-content {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed, 1.7);
	}
	.article-content :global(p) {
		margin-bottom: 1.5em;
	}
	.article-content :global(h2) {
		font-family: var(--font-serif, Georgia, serif);
		font-size: var(--font-size-2xl);
		margin-top: 2em;
		margin-bottom: 0.6em;
	}
	.article-content :global(h3) {
		font-family: var(--font-serif, Georgia, serif);
		font-size: var(--font-size-xl);
		margin-top: 1.6em;
		margin-bottom: 0.5em;
	}
	.article-content :global(blockquote) {
		margin: 2em 0;
		padding: var(--spacing-4) var(--spacing-6);
		border-left: 3px solid var(--color-border);
		background: var(--color-bg-subtle);
		color: var(--color-text-secondary);
		font-style: italic;
	}
	.article-content :global(ul),
	.article-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.5em;
	}
	.article-content :global(li) {
		margin-bottom: 0.5em;
	}
	.article-content :global(img) {
		margin: 2em 0;
		border-radius: var(--radius-lg, var(--radius));
		width: 100%;
	}
	.article-content :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.article-foot {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}
	.foot-link {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-muted);
		text-decoration: none;
	}
	.foot-link:hover {
		color: var(--color-text);
	}
	@media (max-width: 600px) {
		.article-title {
			font-size: var(--font-size-3xl);
		}
		.article-excerpt {
			font-size: var(--font-size-lg);
		}
	}
</style>
