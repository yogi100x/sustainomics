		<script>
			// ⌘K / Ctrl+K to focus search
			document.addEventListener("keydown", (e) => {
				if ((e.metaKey || e.ctrlKey) && e.key === "k") {
					e.preventDefault();
					const searchInput = document.querySelector(
						".snav-search-input"
					) as HTMLInputElement;
					if (searchInput) {
						searchInput.focus();
					}
				}
			});
		</script>
