---
import {
	getEmDashCollection,
	getTermsForEntries,
	getSiteSettings,
} from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { getReadingTime } from "../utils/reading-time";
import { resolveBlogSiteIdentity } from "../utils/site-identity";
import AdBlock from "../components/AdBlock.astro";
import VideoWidget from "../components/VideoWidget.astro";
import { SECTIONS } from "../config/site-nav";

const POSTS_LIMIT = 16;

const [{ entries: posts, cacheHint }, settings] = await Promise.all([
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: POSTS_LIMIT + 1,
	}),
	getSiteSettings(),
]);
const { siteTitle, siteTagline } = resolveBlogSiteIdentity(settings);
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const visible = posts.slice(0, POSTS_LIMIT);
const ids = visible.map((p) => p.data.id);
const catsByEntry = await getTermsForEntries("posts", ids, "category");

function cat(post: (typeof visible)[number]) {
	const c = catsByEntry.get(post.data.id)?.[0];
	return c ? { label: c.label, slug: c.slug } : null;
}
function fmtDate(d: Date | null | undefined) {
	if (!d) return null;
	return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}
function bylineNames(post: (typeof visible)[number]) {
	return (post.data.bylines ?? [])
		.map((b) => b.byline?.displayName)
		.filter(Boolean);
}
function leadByline(post: (typeof visible)[number]) {
	const c = (post.data.bylines ?? [])[0];
	if (!c) return null;
	return { name: c.byline?.displayName ?? "", role: c.roleLabel ?? "Columnist" };
}
function initials(name: string) {
	return (name || "")
		.replace(/^Dr\.?\s*/i, "")
		.split(/\s+/)
		.map((w) => w[0])
		.join("")
		.slice(0, 2)
		.toUpperCase();
}

// Split opinion out so it gets its own dedicated module.
const isOpinion = (p: (typeof visible)[number]) => cat(p)?.slug === "opinion";
const news = visible.filter((p) => !isOpinion(p));
const opinion = visible.filter(isOpinion);

const lead = news[0];
const subHeadlines = news.slice(1, 4);
const feature = news[4];
const twoUp = news.slice(5, 7);
const moreRow = news.slice(7, 10);

const opLead = opinion[0];
const opRest = opinion.slice(1, 4);
const latest = visible.slice(0, 8);

const leadCat = lead ? cat(lead) : null;
const leadBy = lead ? bylineNames(lead) : [];
const featureCat = feature ? cat(feature) : null;
const featureBy = feature ? bylineNames(feature) : [];
const opLeadBy = opLead ? leadByline(opLead) : null;

// Homepage modules pulling from the Podcast + Magazine collections.
const [{ entries: pods }, { entries: mags }, { entries: bandPostsRaw }] = await Promise.all([
	getEmDashCollection("podcasts", { limit: 8 }),
	getEmDashCollection("magazines", { limit: 6 }),
	getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 80 }),
]);

// Group top 3 posts per news section for category bands
const NEWS_SECTIONS = SECTIONS.filter((s) => s.kind === "category");
const bandIds = bandPostsRaw.map((p) => p.data.id);
const bandCats = await getTermsForEntries("posts", bandIds, "category");
const postsBySection: Record<string, typeof bandPostsRaw> = {};
for (const post of bandPostsRaw) {
	const cats = bandCats.get(post.data.id) ?? [];
	for (const c of cats) {
		if (!postsBySection[c.slug]) postsBySection[c.slug] = [];
		if (postsBySection[c.slug].length < 3) {
			postsBySection[c.slug].push(post);
		}
	}
}
const originals = pods.filter((p) => p.data.video_url).slice(0, 4);
const latestIssue = mags.toSorted((a, b) => {
	const da = a.data.issue_date ? new Date(a.data.issue_date).getTime() : 0;
	const db = b.data.issue_date ? new Date(b.data.issue_date).getTime() : 0;
	return db - da;
})[0];
function ytId(u?: string | null) {
	if (!u) return null;
	const m = u.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)([\w-]{11})/);
	return m ? m[1] : null;
}

---

<Base title={siteTitle} description={siteTagline}>
	{
		visible.length === 0 ? (
			<section class="empty-state">
				<h2>No articles yet</h2>
				<p>Create your first article in the admin panel.</p>
				<a href="/_emdash/admin/content/posts/new" class="btn">
					Create an article
				</a>
			</section>
		) : (
			<>
				<div class="page">
					<div class="content">
						{/* ===== HERO ===== */}
						<article class="hero">
							{lead.data.featured_image && (
								<a href={`/posts/${lead.id}`} class="hero-media">
									<Image image={lead.data.featured_image} />
								</a>
							)}
							<div class="hero-body">
								{leadCat && (
									<a class="kicker" href={`/category/${leadCat.slug}`}>
										{leadCat.label}
									</a>
								)}
								<a href={`/posts/${lead.id}`} class="hl-link">
									<h1 class="hl hl--hero">{lead.data.title}</h1>
								</a>
								{lead.data.excerpt && <p class="dek">{lead.data.excerpt}</p>}
								<div class="byline">
									{leadBy.length > 0 && <span class="by">By {leadBy.join(", ")}</span>}
									{fmtDate(lead.data.publishedAt) && (
										<>
											<span class="dot" />
											<time>{fmtDate(lead.data.publishedAt)}</time>
										</>
									)}
									<span class="dot" />
									<span>{getReadingTime(lead.data.content)} min read</span>
								</div>
							</div>
						</article>

						<AdBlock placement="mid-page" />

						{/* ===== 3-up text headlines ===== */}
						{subHeadlines.length > 0 && (
							<ul class="headline-row">
								{subHeadlines.map((p) => (
									<li class="hr-item">
										{cat(p) && (
											<a class="kicker sm" href={`/category/${cat(p)!.slug}`}>
												{cat(p)!.label}
											</a>
										)}
										<a href={`/posts/${p.id}`} class="hl-link">
											<h3 class="hl hl--sm">{p.data.title}</h3>
										</a>
									</li>
								))}
							</ul>
						)}

						{/* ===== Feature ===== */}
						{feature && (
							<>
								<hr class="rule" />
								<article class="feature">
									{feature.data.featured_image && (
										<a href={`/posts/${feature.id}`} class="feature-media">
											<Image image={feature.data.featured_image} />
										</a>
									)}
									<div class="feature-body">
										{featureCat && (
											<a class="kicker" href={`/category/${featureCat.slug}`}>
												{featureCat.label}
											</a>
										)}
										<a href={`/posts/${feature.id}`} class="hl-link">
											<h2 class="hl hl--feature">{feature.data.title}</h2>
										</a>
										{feature.data.excerpt && (
											<p class="dek">{feature.data.excerpt}</p>
										)}
										<div class="byline">
											{featureBy.length > 0 && (
												<span class="by">By {featureBy.join(", ")}</span>
											)}
											{fmtDate(feature.data.publishedAt) && (
												<>
													<span class="dot" />
													<time>{fmtDate(feature.data.publishedAt)}</time>
												</>
											)}
										</div>
									</div>
								</article>
							</>
						)}

						{/* ===== Opinion (shaded block) ===== */}
						{opinion.length > 0 && (
							<section class="opinion">
								<a class="op-kicker" href="/category/opinion">
									Sustainomics Opinion
								</a>
								<div class="op-grid">
									{opLead && (
										<article class="op-lead">
											{opLead.data.featured_image && (
												<a href={`/posts/${opLead.id}`} class="op-lead-media">
													<Image image={opLead.data.featured_image} />
												</a>
											)}
											<div>
												<a href={`/posts/${opLead.id}`} class="hl-link">
													<h2 class="hl hl--op">{opLead.data.title}</h2>
												</a>
												{opLead.data.excerpt && (
													<p class="dek">{opLead.data.excerpt}</p>
												)}
												{opLeadBy && (
													<p class="op-by">
														By {opLeadBy.name}
														<span class="op-role">, {opLeadBy.role}</span>
													</p>
												)}
											</div>
										</article>
									)}
									{opRest.length > 0 && (
										<ul class="op-list">
											{opRest.map((p) => {
												const b = leadByline(p);
												return (
													<li class="op-item">
														<span class="op-avatar">
															{b ? initials(b.name) : "•"}
														</span>
														<div>
															<a href={`/posts/${p.id}`} class="hl-link">
																<h4 class="hl hl--opsm">{p.data.title}</h4>
															</a>
															{b && (
																<p class="op-by">
																	By {b.name}
																	<span class="op-role">, {b.role}</span>
																</p>
															)}
														</div>
													</li>
												);
											})}
										</ul>
									)}
								</div>
							</section>
						)}

						{/* ===== Two-up ===== */}
						{twoUp.length > 0 && (
							<>
								<AdBlock placement="mid-page" />

								<hr class="rule" />
								<div class="two-up">
									{twoUp.map((p) => (
										<article class="cardb">
											{p.data.featured_image && (
												<a href={`/posts/${p.id}`} class="cardb-media">
													<Image image={p.data.featured_image} />
												</a>
											)}
											{cat(p) && (
												<a class="kicker" href={`/category/${cat(p)!.slug}`}>
													{cat(p)!.label}
												</a>
											)}
											<a href={`/posts/${p.id}`} class="hl-link">
												<h3 class="hl hl--card">{p.data.title}</h3>
											</a>
											{p.data.excerpt && <p class="dek">{p.data.excerpt}</p>}
										</article>
									))}
								</div>
							</>
						)}

						{/* ===== More (3-up minis) ===== */}
						{moreRow.length > 0 && (
							<>
								<hr class="rule" />
								<div class="more-row">
									{moreRow.map((p) => (
										<article class="mini">
											{p.data.featured_image && (
												<a href={`/posts/${p.id}`} class="mini-media">
													<Image image={p.data.featured_image} />
												</a>
											)}
											{cat(p) && (
												<a class="kicker sm" href={`/category/${cat(p)!.slug}`}>
													{cat(p)!.label}
												</a>
											)}
											<a href={`/posts/${p.id}`} class="hl-link">
												<h3 class="hl hl--mini">{p.data.title}</h3>
											</a>
										</article>
									))}
								</div>
							</>
						)}

						{/* ===== Sustainomics Originals (video) ===== */}
						{originals.length > 0 && (
							<>
								<hr class="rule" />
								<section class="originals">
									<div class="band-head">
										<h2 class="band-name">Sustainomics Originals</h2>
										<a href="/podcast" class="band-link">All video &amp; audio →</a>
									</div>
									<div class="orig-grid">
										{originals.map((e) => (
											<a class="orig-card" href={`/podcast/${e.id}`}>
												<div class="orig-thumb">
													{e.data.cover ? (
														<Image image={e.data.cover} />
													) : ytId(e.data.video_url) ? (
														<img
															src={`https://i.ytimg.com/vi/${ytId(e.data.video_url)}/hqdefault.jpg`}
															alt={e.data.title}
														/>
													) : (
														<div class="noimg" />
													)}
													<span class="play" aria-hidden="true">▶</span>
													{e.data.duration && <span class="dur">{e.data.duration}</span>}
												</div>
												<h3 class="orig-title">{e.data.title}</h3>
											</a>
										))}
									</div>
								</section>
							</>
						)}

						{/* ===== From the Magazine ===== */}
						{latestIssue && (
							<>
								<hr class="rule" />
								<section class="mag-teaser">
									<a class="mag-teaser-cover" href={`/magazine/${latestIssue.id}`}>
										{latestIssue.data.cover ? (
											<Image image={latestIssue.data.cover} />
										) : (
											<div class="mag-teaser-fallback">
												<span class="mtf-kicker">Sustainomics</span>
												<span class="mtf-title">{latestIssue.data.title}</span>
											</div>
										)}
									</a>
									<div class="mag-teaser-body">
										<span class="kicker">From the Magazine</span>
										<a href={`/magazine/${latestIssue.id}`} class="hl-link">
											<h2 class="hl hl--feature">{latestIssue.data.title}</h2>
										</a>
										{latestIssue.data.excerpt && (
											<p class="dek">{latestIssue.data.excerpt}</p>
										)}
										<a href={`/magazine/${latestIssue.id}`} class="mag-cta">
											Read the issue →
										</a>
									</div>
								</section>
							</>
						)}

						{/* ===== CATEGORY BANDS ===== */}
						{NEWS_SECTIONS.map((section) => {
							const sectionPosts = postsBySection[section.slug] ?? [];
							if (sectionPosts.length === 0) return null;
							return (
								<>
									<hr class="rule" />
									<section class="cat-band">
										<div class="cat-band-head">
											<a href={section.href} class="cat-band-name">{section.label}</a>
											<a href={section.href} class="cat-band-more">More {section.label} →</a>
										</div>
										<div class="cat-band-grid">
											{sectionPosts.map((post) => (
												<article class="cat-band-card">
													{post.data.featured_image && (
														<a href={`/posts/${post.id}`} class="cat-band-media">
															<Image image={post.data.featured_image} />
														</a>
													)}
													<a href={`/posts/${post.id}`} class="hl-link">
														<h3 class="hl hl--card">{post.data.title}</h3>
													</a>
													{post.data.excerpt && (
														<p class="cat-band-dek">{post.data.excerpt}</p>
													)}
												</article>
											))}
										</div>
									</section>
								</>
							);
						})}
					</div>

					{/* ===== RIGHT RAIL ===== */}
					<aside class="rail">
						<VideoWidget />

						<section class="latest">
							<h2 class="latest-head">Latest</h2>
							<ol class="latest-list">
								{latest.map((p) => (
									<li class="lt-item">
										{cat(p) && <span class="lt-kicker">{cat(p)!.label}</span>}
										<a href={`/posts/${p.id}`} class="lt-title">
											{p.data.title}
										</a>
									</li>
								))}
							</ol>
							<a href="/posts" class="see-all">See all coverage →</a>
						</section>

						<AdBlock placement="sidebar" />

					<section class="signup">
							<h3 class="signup-head">The transition, in your inbox</h3>
							<p class="signup-dek">
								A weekly brief on the markets, policy, and technology driving
								decarbonization.
							</p>
							<form class="signup-form" onsubmit="return false">
								<input type="email" placeholder="Enter your email" aria-label="Email" />
								<button type="submit">Sign Up</button>
							</form>
						</section>
					</aside>
				</div>
			</>
		)
	}
</Base>

<style>
	/* ===== Page grid ===== */
	.page {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
		display: grid;
		grid-template-columns: minmax(0, 1fr) 320px;
		gap: var(--spacing-12);
	}

	.content {
		min-width: 0;
	}

	/* ===== Shared ===== */
	.hl {
		font-family: var(--font-serif, Georgia, serif);
		color: var(--color-ink);
		font-weight: 700;
		line-height: 1.13;
		letter-spacing: -0.01em;
	}

	.hl-link {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.hl-link:hover .hl {
		color: var(--color-accent);
	}

	.hl--hero {
		font-size: clamp(1.9rem, 3.1vw, 2.85rem);
		margin: var(--spacing-1) 0 var(--spacing-3);
	}

	.hl--feature {
		font-size: clamp(1.5rem, 2.4vw, 2rem);
		margin: var(--spacing-1) 0 var(--spacing-2);
	}

	.hl--card {
		font-size: var(--font-size-xl);
		margin: var(--spacing-1) 0 var(--spacing-2);
	}

	.hl--sm {
		font-size: 1.0625rem;
		line-height: 1.25;
		margin-top: var(--spacing-1);
	}

	.hl--mini {
		font-size: var(--font-size-lg);
		margin-top: var(--spacing-2);
	}

	.kicker {
		display: inline-block;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wide);
		color: var(--color-ink);
		text-decoration: none;
	}

	.kicker:hover {
		color: var(--color-kicker);
	}

	.kicker.sm {
		font-size: 0.6875rem;
	}

	.dek {
		font-family: var(--font-sans);
		font-size: 0.95rem;
		line-height: 1.5;
		color: var(--color-text-secondary);
		margin-top: var(--spacing-2);
	}

	.byline {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-3);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	.byline .by {
		color: var(--color-text-secondary);
		font-weight: 600;
	}

	.dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-muted);
	}

	.rule {
		height: 0;
		border: 0;
		border-top: 1px solid var(--color-border);
		margin: var(--spacing-8) 0;
	}

	/* ===== Hero ===== */
	.hero {
		display: grid;
		grid-template-columns: 1.15fr 1fr;
		gap: var(--spacing-8);
		align-items: start;
	}

	.hero-media,
	.feature-media,
	.cardb-media,
	.mini-media,
	.op-lead-media {
		display: block;
		overflow: hidden;
		background: var(--color-surface);
	}

	.hero-media :global(img) {
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 2;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.hero-media:hover :global(img),
	.feature-media:hover :global(img),
	.cardb-media:hover :global(img),
	.mini-media:hover :global(img),
	.op-lead-media:hover :global(img) {
		transform: scale(1.02);
	}

	/* ===== 3-up headline row ===== */
	.headline-row {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		margin-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-4);
	}

	.hr-item {
		padding: 0 var(--spacing-5);
		border-left: 1px solid var(--color-border-subtle);
	}

	.hr-item:first-child {
		padding-left: 0;
		border-left: none;
	}

	.hr-item:last-child {
		padding-right: 0;
	}

	/* ===== Feature ===== */
	.feature {
		display: grid;
		grid-template-columns: 0.9fr 1.1fr;
		gap: var(--spacing-8);
		align-items: start;
	}

	.feature-media :global(img),
	.cardb-media :global(img) {
		width: 100%;
		height: auto;
		aspect-ratio: 3 / 2;
		object-fit: cover;
	}

	/* ===== Category bands ===== */
	.cat-band {
		margin-top: var(--spacing-6);
	}
	.cat-band-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		border-bottom: 2px solid var(--color-ink);
		padding-bottom: var(--spacing-2);
		margin-bottom: var(--spacing-6);
	}
	.cat-band-name {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-ink);
		text-decoration: none;
	}
	.cat-band-name:hover { color: var(--color-accent); }
	.cat-band-more {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		color: var(--color-muted);
		text-decoration: none;
		white-space: nowrap;
	}
	.cat-band-more:hover { color: var(--color-accent); }
	.cat-band-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
	}
	.cat-band-card {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}
	.cat-band-media {
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--color-surface);
		margin-bottom: var(--spacing-2);
	}
