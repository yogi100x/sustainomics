---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import AdBlock from "../../components/AdBlock.astro";
import { SECTIONS } from "../../config/site-nav";

const opinionSection = SECTIONS.find((s) => s.slug === "podcast")!;
const SHOWS = opinionSection.subtabs;

const { entries: eps, cacheHint } = await getEmDashCollection("podcasts", {
	orderBy: { episode_date: "desc" },
	limit: 80,
});
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

function ytId(u?: string | null) {
	if (!u) return null;
	const m = u.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)([-\w]{11})/);
	return m ? m[1] : null;
}

const fmt = (d: Date | string | null | undefined) => {
	if (!d) return null;
	const date = d instanceof Date ? d : new Date(d as string);
	return isNaN(date.getTime())
		? null
		: date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};

// All episodes regardless of show — latest 3 for the featured strip
const featured = eps.slice(0, 3);

// Group by show name matching subtab label (first word match is enough)
// Episodes without a show tag fall under the first show as default
const epsByShow: Record<string, typeof eps> = {};
for (const show of SHOWS) epsByShow[show.label] = [];
for (const ep of eps) {
	const title = ep.data.title ?? "";
	const matched = SHOWS.find((s) =>
		title.toLowerCase().includes(s.slug.replace(/-/g, " "))
	);
	const key = matched?.label ?? SHOWS[0].label;
	if (epsByShow[key].length < 3) epsByShow[key].push(ep);
}
---

<Base title="Opinion" description={opinionSection.blurb}>
	<div class="wrap">

		{/* ===== MASTHEAD ===== */}
		<header class="sec-head">
			<h1 class="sec-name">Opinion</h1>
			<p class="sec-sub">{opinionSection.blurb}</p>
		</header>

		{/* ===== SHOW TABS NAV ===== */}
		<nav class="show-tabs" aria-label="Opinion shows">
			{SHOWS.map((show) => (
				<a href={`#show-${show.slug}`} class="show-tab">{show.label}</a>
			))}
		</nav>

		{eps.length === 0 ? (
			<section class="empty">
				<h2>No episodes yet</h2>
				<p>Publish your first episode in the admin panel.</p>
				<a class="btn" href="/_emdash/admin/content/podcasts/new">Add an episode</a>
			</section>
		) : (
			<>
				{/* ===== FEATURED STRIP (latest 3) ===== */}
				<section class="featured-strip">
					{featured.map((ep, i) => {
						const vid = ytId(ep.data.video_url);
						return (
							<a href={`/podcast/${ep.id}`} class:list={["feat-card", { "feat-card--lead": i === 0 }]}>
								<div class="feat-media">
									{ep.data.cover ? (
										<Image image={ep.data.cover} />
									) : vid ? (
										<img src={`https://i.ytimg.com/vi/${vid}/hqdefault.jpg`} alt={ep.data.title} loading="lazy" />
									) : (
										<div class="feat-noimg" />
									)}
									{ep.data.video_url && <span class="feat-play" aria-hidden="true">▶</span>}
								</div>
								<div class="feat-body">
									<span class="feat-kicker">Opinion</span>
									<h2 class="feat-title">{ep.data.title}</h2>
									{ep.data.excerpt && <p class="feat-dek">{ep.data.excerpt}</p>}
									<div class="feat-meta">
										{ep.data.duration && <span class="feat-dur">{ep.data.video_url ? "▶" : "🎧"} {ep.data.duration}</span>}
										{fmt(ep.data.episode_date) && <span class="feat-date">{fmt(ep.data.episode_date)}</span>}
									</div>
								</div>
							</a>
						);
					})}
				</section>

				<AdBlock placement="mid-page" />

				{/* ===== NAMED SHOW BANDS ===== */}
				{SHOWS.map((show) => {
					const showEps = epsByShow[show.label] ?? [];
					return (
						<section class="show-band" id={`show-${show.slug}`}>
							<div class="show-head">
								<div class="show-head-text">
									<h2 class="show-name">{show.label}</h2>
									<p class="show-desc">{show.desc}</p>
								</div>
								<a href="/podcast" class="show-all">All episodes →</a>
							</div>
							{showEps.length === 0 ? (
								<p class="show-empty">Episodes coming soon.</p>
							) : (
								<div class="show-grid">
									{showEps.map((ep) => {
										const vid = ytId(ep.data.video_url);
										return (
											<a href={`/podcast/${ep.id}`} class="ep-card">
												<div class="ep-media">
													{ep.data.cover ? (
														<Image image={ep.data.cover} />
													) : vid ? (
														<img src={`https://i.ytimg.com/vi/${vid}/hqdefault.jpg`} alt={ep.data.title} loading="lazy" />
													) : (
														<div class="ep-noimg" />
													)}
													{ep.data.video_url && <span class="ep-play" aria-hidden="true">▶</span>}
												</div>
												<div class="ep-body">
													<h3 class="ep-title">{ep.data.title}</h3>
													{ep.data.excerpt && <p class="ep-dek">{ep.data.excerpt}</p>}
													<div class="ep-meta">
														{ep.data.duration && <span class="ep-dur">{ep.data.video_url ? "▶" : "🎧"} {ep.data.duration}</span>}
														{fmt(ep.data.episode_date) && <span class="ep-date">{fmt(ep.data.episode_date)}</span>}
													</div>
												</div>
											</a>
										);
									})}
								</div>
							)}
						</section>
					);
				})}
			</>
		)}
	</div>
</Base>

<style>
	.wrap {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	/* Masthead */
	.sec-head {
		border-top: 2px solid var(--color-ink);
		padding-top: var(--spacing-3);
		margin-bottom: var(--spacing-6);
	}
	.sec-name {
		font-family: var(--font-serif, Georgia, serif);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		color: var(--color-ink);
	}
	.sec-sub {
		margin-top: var(--spacing-1);
		color: var(--color-muted);
		max-width: 60ch;
	}

	/* Show tabs nav */
	.show-tabs {
		display: flex;
		gap: var(--spacing-4);
		overflow-x: auto;
		scrollbar-width: none;
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-8);
		padding-bottom: 0;
	}
	.show-tabs::-webkit-scrollbar { display: none; }
	.show-tab {
		flex: none;
		padding: var(--spacing-3) 0;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		white-space: nowrap;
		color: var(--color-text-secondary);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
		transition: color var(--transition-fast), border-color var(--transition-fast);
	}
	.show-tab:hover {
		color: var(--color-ink);
		border-bottom-color: var(--color-kicker);
	}

	/* Featured strip */
	.featured-strip {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: var(--spacing-6);
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-10);
		border-bottom: 1px solid var(--color-border);
	}
	.feat-card {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}
	.feat-card--lead {
		grid-column: span 1;
	}
	.feat-media {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--color-surface);
	}
	.feat-media :global(img) {
		width: 100%; height: 100%; object-fit: cover;
		transition: transform 0.3s ease;
	}
	.feat-card:hover .feat-media :global(img) { transform: scale(1.03); }
	.feat-noimg { width: 100%; height: 100%; background: var(--color-surface); }
	.feat-play {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 36px; height: 36px;
		background: rgba(0,0,0,0.6);
		color: #fff;
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-size: 13px; padding-left: 2px;
	}
	.feat-body { display: flex; flex-direction: column; gap: var(--spacing-2); }
	.feat-kicker {
		font-family: var(--font-sans);
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-kicker);
	}
	.feat-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: var(--font-size-xl);
		font-weight: 700;
		line-height: 1.2;
		color: var(--color-ink);
		margin: 0;
	}
	.feat-card:hover .feat-title { color: var(--color-accent); }
	.feat-dek {
		font-size: var(--font-size-sm);
		line-height: 1.5;
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.feat-meta {
		display: flex;
		gap: var(--spacing-3);
		align-items: center;
		margin-top: auto;
	}
	.feat-dur, .feat-date {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	/* Show bands */
	.show-band {
		margin-bottom: var(--spacing-12);
		padding-top: var(--spacing-8);
		border-top: 2px solid var(--color-ink);
	}
	.show-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: var(--spacing-4);
		margin-bottom: var(--spacing-6);
	}
	.show-name {
		font-family: var(--font-sans);
		font-size: var(--font-size-lg);
		font-weight: 700;
		color: var(--color-ink);
		margin: 0;
	}
	.show-desc {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin: var(--spacing-1) 0 0;
		max-width: 52ch;
	}
	.show-all {
		font-size: var(--font-size-xs);
		font-weight: 600;
		color: var(--color-muted);
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
		padding-top: 4px;
	}
	.show-all:hover { color: var(--color-accent); }
	.show-empty {
		color: var(--color-muted);
		font-style: italic;
		font-size: var(--font-size-sm);
	}
	.show-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-6);
	}

	/* Episode card */
	.ep-card {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}
	.ep-media {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--color-surface);
	}
	.ep-media :global(img) {
		width: 100%; height: 100%; object-fit: cover;
		transition: transform 0.3s ease;
	}
	.ep-card:hover .ep-media :global(img) { transform: scale(1.03); }
	.ep-noimg { width: 100%; height: 100%; background: var(--color-surface); }
	.ep-play {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 32px; height: 32px;
		background: rgba(0,0,0,0.6);
		color: #fff;
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-size: 11px; padding-left: 2px;
	}
	.ep-body { display: flex; flex-direction: column; gap: var(--spacing-1); }
	.ep-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: var(--font-size-base);
		font-weight: 700;
		line-height: 1.3;
		color: var(--color-ink);
		margin: 0;
	}
	.ep-card:hover .ep-title { color: var(--color-accent); }
	.ep-dek {
		font-size: var(--font-size-sm);
		line-height: 1.45;
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.ep-meta { display: flex; gap: var(--spacing-3); align-items: center; }
	.ep-dur, .ep-date { font-size: var(--font-size-xs); color: var(--color-muted); }

	/* Empty */
	.empty { text-align: center; padding: var(--spacing-20) var(--spacing-6); }
	.empty h2 { font-family: var(--font-serif, Georgia, serif); font-size: var(--font-size-2xl); }
	.empty p { color: var(--color-muted); margin-top: var(--spacing-2); }
	.btn {
		display: inline-block; margin-top: var(--spacing-4);
		padding: var(--spacing-3) var(--spacing-6);
		background: var(--color-ink); color: #fff;
		text-decoration: none; font-size: var(--font-size-sm); font-weight: 600;
	}

	@media (max-width: 900px) {
		.featured-strip { grid-template-columns: 1fr 1fr; }
		.featured-strip .feat-card:last-child { display: none; }
		.show-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) {
		.featured-strip { grid-template-columns: 1fr; }
		.show-grid { grid-template-columns: 1fr; }
	}
</style>
