---
import { getEmDashCollection } from "emdash";

interface Props {
	placement: "sidebar" | "leaderboard" | "homepage" | "article";
	class?: string;
}

const { placement, class: className } = Astro.props;

const { entries: allAds } = await getEmDashCollection("advertisements");
const ads = allAds.filter(
	(ad) => ad.data.placement?.trim().toLowerCase() === placement
);

function mediaUrl(img: any): string | null {
	if (!img) return null;
	if (img?.meta?.storageKey) {
		const ext = img.filename?.split(".").pop() ?? "jpg";
		return `/_emdash/api/media/file/${img.meta.storageKey}.${ext}`;
	}
	return img?.url ?? null;
}
---

{ads.length > 0 && (
	<div class={`ad-zone ad-zone--${placement}${className ? ` ${className}` : ""}`}>
		{ads.map((ad) => {
			const imgUrl = mediaUrl(ad.data.image);
			const label = ad.data.sponsor_label || "Advertisement";
			const inner = imgUrl
				? <img src={imgUrl} alt={ad.data.title} class="ad-img" loading="lazy" />
				: <div class="ad-placeholder"><span class="ad-placeholder-text">{ad.data.title}</span></div>;
			return (
				<div class="ad-block">
					<p class="ad-label">{label}</p>
					{ad.data.link_url ? (
						<a href={ad.data.link_url} target="_blank" rel="noopener sponsored" class="ad-link">
							{inner}
						</a>
					) : inner}
				</div>
			);
		})}
	</div>
)}

<style>
	.ad-zone {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.ad-zone--leaderboard {
		align-items: center;
		padding: 0.75rem 0;
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		margin-bottom: 1rem;
	}

	.ad-block {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.ad-label {
		font-size: 10px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0;
	}

	.ad-link {
		display: block;
	}

	.ad-img {
		width: 100%;
		height: auto;
		display: block;
	}

	.ad-placeholder {
		width: 100%;
		min-height: 120px;
		background: var(--color-surface, #f3f4f6);
		border: 1px dashed var(--color-border, #d1d5db);
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
	}

	.ad-placeholder-text {
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--color-muted, #9ca3af);
		text-align: center;
	}
</style>
