---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";

const { entries: allPods } = await getEmDashCollection("podcasts", {
	orderBy: { episode_date: "desc" },
	limit: 10,
});

const videos = allPods.filter((ep) => ep.data.video_url).slice(0, 3);

function ytId(u?: string | null) {
	if (!u) return null;
	const m = u.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)(\w[\w-]{10})/);
	return m ? m[1] : null;
}
---

{videos.length > 0 && (
	<section class="vid-widget">
		<div class="vid-widget-head">
			<h3 class="vid-widget-title">Video</h3>
			<a href="/video" class="vid-widget-all">All video →</a>
		</div>

		<div class="vid-carousel">
			{videos.map((ep, i) => {
				const vid = ytId(ep.data.video_url);
				return (
					<div class:list={["vid-slide", { "vid-slide--hidden": i !== 0 }]} data-vidslide={i}>
						<a href={`/podcast/${ep.id}`} class="vid-link">
							<div class="vid-thumb">
								{ep.data.cover ? (
									<Image image={ep.data.cover} />
								) : vid ? (
									<img
										src={`https://i.ytimg.com/vi/${vid}/hqdefault.jpg`}
										alt={ep.data.title}
										loading="lazy"
									/>
								) : (
									<div class="vid-noimg" />
								)}
								<span class="vid-play" aria-hidden="true">▶</span>
							</div>
							<h4 class="vid-slide-title">{ep.data.title}</h4>
						</a>
					</div>
				);
			})}
		</div>

		{videos.length > 1 && (
			<div class="vid-dots">
				{videos.map((_, i) => (
					<button
						type="button"
						class:list={["vid-dot", { "vid-dot--active": i === 0 }]}
						data-viddot={i}
						aria-label={`Video ${i + 1}`}
					/>
				))}
			</div>
		)}
	</section>
)}

<script>
	document.querySelectorAll<HTMLElement>('.vid-widget').forEach(widget => {
		const carousel = widget.querySelector<HTMLElement>('.vid-carousel');
		if (!carousel) return;
		const slides = Array.from(carousel.querySelectorAll<HTMLElement>('[data-vidslide]'));
		const dots = Array.from(widget.querySelectorAll<HTMLElement>('[data-viddot]'));
		if (slides.length < 2) return;

		let current = 0;

		function goTo(n: number) {
			slides[current].classList.add('vid-slide--hidden');
			dots[current]?.classList.remove('vid-dot--active');
			current = n;
			slides[current].classList.remove('vid-slide--hidden');
			dots[current]?.classList.add('vid-dot--active');
		}

		dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

		let timer = setInterval(() => goTo((current + 1) % slides.length), 6000);
		widget.addEventListener('mouseenter', () => clearInterval(timer));
		widget.addEventListener('mouseleave', () => {
			timer = setInterval(() => goTo((current + 1) % slides.length), 6000);
		});
	});
</script>

<style>
	.vid-widget {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.vid-widget-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		border-bottom: 2px solid var(--color-ink);
		padding-bottom: var(--spacing-2);
	}

	.vid-widget-title {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--color-ink);
		margin: 0;
	}

	.vid-widget-all {
		font-size: var(--font-size-xs);
		font-weight: 600;
		color: var(--color-muted);
		text-decoration: none;
	}
	.vid-widget-all:hover { color: var(--color-accent); }

	/* Carousel grid overlay — same crossfade pattern as leaderboard */
	.vid-carousel {
		display: grid;
	}
	.vid-slide {
		grid-area: 1 / 1;
		transition: opacity 0.5s ease;
	}
	.vid-slide--hidden {
		opacity: 0;
		pointer-events: none;
	}

	.vid-link {
		text-decoration: none;
		color: inherit;
		display: block;
	}

	.vid-thumb {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--color-surface);
	}
	.vid-thumb :global(img),
	.vid-thumb :global(picture img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.vid-noimg {
		width: 100%;
		height: 100%;
		background: var(--color-surface);
	}

	.vid-play {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 40px;
		height: 40px;
		background: rgba(0,0,0,0.65);
		color: #fff;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 14px;
		padding-left: 3px;
		transition: background var(--transition-fast);
	}
	.vid-link:hover .vid-play { background: var(--color-kicker); }

	.vid-slide-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--color-ink);
		margin: var(--spacing-3) 0 0;
	}
	.vid-link:hover .vid-slide-title { color: var(--color-accent); }

	/* Dot navigation */
	.vid-dots {
		display: flex;
		gap: 6px;
		justify-content: center;
		padding-top: var(--spacing-2);
	}
	.vid-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		border: none;
		background: var(--color-border);
		cursor: pointer;
		padding: 0;
		transition: background var(--transition-fast);
	}
	.vid-dot--active { background: var(--color-ink); }
	.vid-dot:hover { background: var(--color-text-secondary); }
</style>
