---
import { getEmDashCollection } from "emdash";

interface Props {
	placement: "sidebar" | "leaderboard" | "mid-page" | "homepage" | "article";
	class?: string;
}

const { placement, class: className } = Astro.props;

const { entries: allAds } = await getEmDashCollection("advertisements");
const ads = allAds.filter(
	(ad) => ad.data.placement?.trim().toLowerCase() === placement
);

function mediaUrl(img: any): string | null {
	if (!img) return null;
	if (img?.meta?.storageKey) {
		return `/_emdash/api/media/file/${img.meta.storageKey}`;
	}
	return img?.url ?? null;
}

const BRAND_COLORS = ["#1a6b3c", "#0f4c81", "#8b1a1a", "#5c3d8f", "#b45309"];
---

{ads.length > 0 && (
	<div class={`ad-zone ad-zone--${placement}${className ? ` ${className}` : ""}${['leaderboard','mid-page'].includes(placement) ? ' ad-zone--rotating' : ''}`}
		data-rotating={['leaderboard','mid-page'].includes(placement) ? 'true' : undefined}>
		{ads.map((ad, i) => {
			const imgUrl = mediaUrl(ad.data.image);
			const label = ad.data.sponsor_label || "Advertisement";
			const brandColor = BRAND_COLORS[i % BRAND_COLORS.length];
			const brandName = label.replace(/^Sponsored by /i, "");

			const inner = imgUrl ? (
				<img src={imgUrl} alt={ad.data.title} class="ad-img" loading="lazy" />
			) : (
				<div class="ad-mock" style={`--brand: ${brandColor}`}>
					<div class="ad-mock-header">
						<span class="ad-mock-brand">{brandName}</span>
					</div>
					<div class="ad-mock-body">
						<p class="ad-mock-headline">{ad.data.title}</p>
						<span class="ad-mock-cta">Learn More →</span>
					</div>
				</div>
			);

				return (
				<div class="ad-block" data-slide={['leaderboard','mid-page'].includes(placement) ? String(i) : undefined}>
					<p class="ad-label">{label}</p>
					{ad.data.link_url ? (
						<a href={ad.data.link_url} target="_blank" rel="noopener sponsored" class="ad-link">
							{inner}
						</a>
					) : inner}
				</div>
			);
		})}
	</div>
)}

<script>
	document.querySelectorAll<HTMLElement>('.ad-zone--rotating').forEach(zone => {
		const slides = Array.from(zone.querySelectorAll<HTMLElement>('[data-slide]'));
		if (slides.length < 2) return;
		let current = 0;
		slides.forEach((s, i) => s.classList.toggle('ad-slide-hidden', i !== 0));
		setInterval(() => {
			slides[current].classList.add('ad-slide-hidden');
			current = (current + 1) % slides.length;
			slides[current].classList.remove('ad-slide-hidden');
		}, 5000);
	});
</script>

<style>
	.ad-zone {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		margin-top: var(--spacing-6);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.ad-zone--rotating {
		display: grid;
		position: relative;
	}
	.ad-zone--rotating .ad-block {
		grid-area: 1 / 1;
		transition: opacity 0.7s ease;
	}
	.ad-zone--rotating .ad-block.ad-slide-hidden {
		opacity: 0;
		pointer-events: none;
		position: absolute;
		width: 100%;
	}

	.ad-zone--leaderboard,
	.ad-zone--mid-page {
		padding: 0.6rem var(--spacing-6) 0;
		border-top: 1px solid var(--color-border);
		margin-top: 0;
		margin-bottom: 0;
		max-width: var(--wide-width);
		margin-left: auto;
		margin-right: auto;
	}

	.ad-zone--leaderboard .ad-block,
	.ad-zone--mid-page .ad-block {
		flex: 1;
		border-top: none;
		padding-top: 0;
		margin-top: 0;
	}

	.ad-zone--leaderboard .ad-mock,
	.ad-zone--mid-page .ad-mock {
		flex-direction: row;
		align-items: center;
		gap: 1.5rem;
	}

	.ad-zone--leaderboard .ad-mock-header,
	.ad-zone--mid-page .ad-mock-header {
		padding: 0.75rem 1.25rem;
		writing-mode: initial;
		white-space: nowrap;
		flex-shrink: 0;
		height: 100%;
		display: flex;
		align-items: center;
	}

	.ad-zone--leaderboard .ad-mock-body,
	.ad-zone--mid-page .ad-mock-body {
		flex-direction: row;
		align-items: center;
		gap: 2rem;
		padding: 0.65rem 1rem;
	}

	.ad-zone--leaderboard .ad-mock-headline,
	.ad-zone--mid-page .ad-mock-headline {
		font-size: 0.9rem;
	}

	.ad-zone--leaderboard .ad-mock-cta,
	.ad-zone--mid-page .ad-mock-cta {
		white-space: nowrap;
	}

	.ad-block {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.ad-label {
		font-size: 9px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin: 0;
	}

	.ad-link {
		display: block;
		text-decoration: none;
	}

	.ad-img {
		width: 100%;
		height: auto;
		display: block;
	}

	/* Bloomberg-style mock ad */
	.ad-mock {
		width: 100%;
		border: 1px solid var(--color-border);
		overflow: hidden;
		background: #fff;
	}

	.ad-mock-header {
		background: var(--brand);
		padding: 0.6rem 1rem;
	}

	.ad-mock-brand {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #fff;
	}

	.ad-mock-body {
		padding: 0.85rem 1rem 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.ad-mock-headline {
		font-family: var(--font-serif, Georgia, serif);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.3;
		color: #111;
		margin: 0;
	}

	.ad-mock-cta {
		display: inline-block;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--brand);
		border-bottom: 1.5px solid var(--brand);
		padding-bottom: 1px;
	}
</style>
