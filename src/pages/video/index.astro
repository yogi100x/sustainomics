---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import AdBlock from "../../components/AdBlock.astro";
import { getSection } from "../../config/site-nav";

const section = getSection("video")!;
const CATEGORIES = section.subtabs;

// Active category filter from URL
const active = Astro.url.searchParams.get("cat") ?? "";

const { entries: videos, cacheHint } = await getEmDashCollection("videos", {
	orderBy: { video_date: "desc" },
	limit: 60,
});
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

function ytId(u?: string | null) {
	if (!u) return null;
	const m = u.match(/(?:youtu\.be\/|[?&]v=|\/embed\/|\/shorts\/)([-\w]{11})/);
	return m ? m[1] : null;
}

function ytUrl(id: string) {
	return `https://www.youtube.com/watch?v=${id}`;
}

function thumb(v: (typeof videos)[number]) {
	const vid = ytId(v.data.video_url);
	if (vid) return `https://i.ytimg.com/vi/${vid}/hqdefault.jpg`;
	return null;
}

const fmt = (d: Date | string | null | undefined) => {
	if (!d) return null;
	const date = d instanceof Date ? d : new Date(d as string);
	return isNaN(date.getTime())
		? null
		: date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};

// Filter by active category (client-side is fine but we do it server-side too)
const filtered = active
	? videos.filter((v) =>
			(v.data.category ?? "").toLowerCase() === active.toLowerCase()
		)
	: videos;

const hero = filtered[0];
const rest = filtered.slice(1);
---

<Base title="Video — Sustainomics" description={section.blurb}>
	<div class="v-wrap">

		{/* ===== MASTHEAD ===== */}
		<header class="v-head">
			<h1 class="v-head-title">Video</h1>
			<p class="v-head-sub">{section.blurb}</p>
		</header>

		{/* ===== CATEGORY FILTER TABS ===== */}
		<nav class="v-cats" aria-label="Video categories">
			<a href="/video" class:list={["v-cat", { "v-cat--on": !active }]}>All</a>
			{CATEGORIES.map((cat) => (
				<a
					href={`/video?cat=${encodeURIComponent(cat.label)}`}
					class:list={["v-cat", { "v-cat--on": active === cat.label }]}
				>
					{cat.label}
				</a>
			))}
		</nav>

		{filtered.length === 0 ? (
			<div class="v-empty">
				<p>No videos in this category yet.</p>
				<a href="/video" class="v-empty-back">← All videos</a>
			</div>
		) : (
			<>
				{/* ===== HERO VIDEO ===== */}
				{hero && (() => {
					const vid = ytId(hero.data.video_url);
					const heroHref = vid ? ytUrl(vid) : `/video/${hero.id}`;
					const heroThumb = thumb(hero);
					return (
						<div class="v-hero">
							<a
								href={heroHref}
								{...(vid ? { target: "_blank", rel: "noopener" } : {})}
								class="v-hero-media"
								aria-label={hero.data.title}
							>
								{hero.data.thumbnail ? (
									<Image image={hero.data.thumbnail} />
								) : heroThumb ? (
									<img src={heroThumb} alt={hero.data.title} />
								) : (
									<div class="v-hero-noimg" />
								)}
								<div class="v-hero-play" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
								</div>
								{hero.data.duration && <span class="v-hero-dur">{hero.data.duration}</span>}
							</a>
							<div class="v-hero-body">
								{hero.data.category && <span class="v-kicker">{hero.data.category}</span>}
								<h2 class="v-hero-title">
									<a
										href={heroHref}
										{...(vid ? { target: "_blank", rel: "noopener" } : {})}
									>
										{hero.data.title}
									</a>
								</h2>
								{hero.data.excerpt && <p class="v-hero-dek">{hero.data.excerpt}</p>}
								<div class="v-hero-meta">
									{fmt(hero.data.video_date) && <span class="v-date">{fmt(hero.data.video_date)}</span>}
									{vid && (
										<a href={ytUrl(vid)} target="_blank" rel="noopener" class="v-yt-link">
											<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
											Watch on YouTube
										</a>
									)}
								</div>
							</div>
						</div>
					);
				})()}

				<AdBlock placement="mid-page" />

				{/* ===== VIDEO GRID ===== */}
				{rest.length > 0 && (
					<section class="v-grid-section">
						<div class="v-grid">
							{rest.map((v) => {
								const vid = ytId(v.data.video_url);
								const href = vid ? ytUrl(vid) : `/video/${v.id}`;
								const t = thumb(v);
								return (
									<a
										href={href}
										{...(vid ? { target: "_blank", rel: "noopener" } : {})}
										class="vc"
									>
										<div class="vc-media">
											{v.data.thumbnail ? (
												<Image image={v.data.thumbnail} />
											) : t ? (
												<img src={t} alt={v.data.title} loading="lazy" />
											) : (
												<div class="vc-noimg" />
											)}
											<div class="vc-play" aria-hidden="true">
												<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
											</div>
											{v.data.duration && <span class="vc-dur">{v.data.duration}</span>}
										</div>
										<div class="vc-body">
											{v.data.category && <span class="v-kicker">{v.data.category}</span>}
											<h3 class="vc-title">{v.data.title}</h3>
											{v.data.excerpt && <p class="vc-dek">{v.data.excerpt}</p>}
											{fmt(v.data.video_date) && <span class="v-date">{fmt(v.data.video_date)}</span>}
										</div>
									</a>
								);
							})}
						</div>
					</section>
				)}
			</>
		)}
	</div>
</Base>

<style>
	.v-wrap {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-8) var(--spacing-6) var(--spacing-16);
	}

	/* Masthead */
	.v-head {
		border-top: 2px solid var(--color-ink);
		padding-top: var(--spacing-3);
		margin-bottom: var(--spacing-5);
	}
	.v-head-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 700;
		color: var(--color-ink);
	}
	.v-head-sub {
		margin-top: var(--spacing-1);
		color: var(--color-muted);
		max-width: 60ch;
	}

	/* Category tabs */
	.v-cats {
		display: flex;
		gap: 0;
		overflow-x: auto;
		scrollbar-width: none;
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--spacing-8);
	}
	.v-cats::-webkit-scrollbar { display: none; }
	.v-cat {
		flex: none;
		padding: var(--spacing-3) var(--spacing-4);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: 0.04em;
		white-space: nowrap;
		color: var(--color-text-secondary);
		text-decoration: none;
		border-bottom: 2px solid transparent;
		margin-bottom: -1px;
		transition: color 0.15s, border-color 0.15s;
	}
	.v-cat:hover { color: var(--color-ink); }
	.v-cat--on {
		color: var(--color-ink);
		border-bottom-color: var(--color-ink);
	}

	/* Shared atoms */
	.v-kicker {
		display: block;
		font-family: var(--font-sans);
		font-size: 0.65rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-kicker);
	}
	.v-date {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	/* Hero */
	.v-hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--spacing-8);
		align-items: center;
		margin-bottom: var(--spacing-10);
		padding-bottom: var(--spacing-10);
		border-bottom: 1px solid var(--color-border);
	}
	.v-hero-media {
		position: relative;
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #111;
	}
	.v-hero-media :global(img) {
		width: 100%; height: 100%; object-fit: cover;
		transition: transform 0.4s ease;
	}
	.v-hero-media:hover :global(img) { transform: scale(1.03); }
	.v-hero-noimg { width: 100%; height: 100%; background: #1a1a1a; }
	.v-hero-play {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 64px; height: 64px;
		background: rgba(0,0,0,0.65);
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		color: #fff;
		transition: background 0.2s, transform 0.2s;
	}
	.v-hero-play svg { width: 28px; height: 28px; margin-left: 4px; }
	.v-hero-media:hover .v-hero-play {
		background: var(--color-accent, #e00);
		transform: translate(-50%, -50%) scale(1.1);
	}
	.v-hero-dur {
		position: absolute;
		bottom: var(--spacing-2);
		right: var(--spacing-2);
		background: rgba(0,0,0,0.75);
		color: #fff;
		font-size: 0.7rem;
		font-weight: 600;
		padding: 2px 6px;
		border-radius: 2px;
	}
	.v-hero-body { display: flex; flex-direction: column; gap: var(--spacing-3); }
	.v-hero-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: clamp(1.4rem, 2.5vw, 2rem);
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
	}
	.v-hero-title a { color: var(--color-ink); text-decoration: none; }
	.v-hero-title a:hover { color: var(--color-accent); }
	.v-hero-dek {
		font-size: var(--font-size-base);
		line-height: 1.6;
		color: var(--color-text-secondary);
		margin: 0;
	}
	.v-hero-meta { display: flex; flex-wrap: wrap; gap: var(--spacing-4); align-items: center; margin-top: var(--spacing-2); }
	.v-yt-link {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-1);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: #ff0000;
		text-decoration: none;
	}
	.v-yt-link:hover { text-decoration: underline; }
	.v-yt-link svg { width: 18px; height: 18px; }

	/* Video grid */
	.v-grid-section { margin-top: var(--spacing-4); }
	.v-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-6) var(--spacing-5);
	}

	/* Video card */
	.vc {
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}
	.vc-media {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: #111;
	}
	.vc-media :global(img) {
		width: 100%; height: 100%; object-fit: cover;
		transition: transform 0.3s ease;
	}
	.vc:hover .vc-media :global(img) { transform: scale(1.05); }
	.vc-noimg { width: 100%; height: 100%; background: #1a1a1a; }
	.vc-play {
		position: absolute;
		top: 50%; left: 50%;
		transform: translate(-50%, -50%);
		width: 38px; height: 38px;
		background: rgba(0,0,0,0.6);
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		color: #fff;
		transition: background 0.2s, transform 0.2s;
		opacity: 0;
	}
	.vc-play svg { width: 16px; height: 16px; margin-left: 2px; }
	.vc:hover .vc-play { opacity: 1; transform: translate(-50%, -50%) scale(1.08); }
	.vc-dur {
		position: absolute;
		bottom: var(--spacing-1);
		right: var(--spacing-1);
		background: rgba(0,0,0,0.8);
		color: #fff;
		font-size: 0.65rem;
		font-weight: 600;
		padding: 1px 5px;
		border-radius: 2px;
	}
	.vc-body { display: flex; flex-direction: column; gap: 2px; }
	.vc-title {
		font-family: var(--font-serif, Georgia, serif);
		font-size: var(--font-size-sm);
		font-weight: 700;
		line-height: 1.3;
		color: var(--color-ink);
		margin: 0;
	}
	.vc:hover .vc-title { color: var(--color-accent); }
	.vc-dek {
		font-size: var(--font-size-xs);
		line-height: 1.4;
		color: var(--color-text-secondary);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* Empty */
	.v-empty {
		text-align: center;
		padding: var(--spacing-16) var(--spacing-6);
		color: var(--color-muted);
	}
	.v-empty-back {
		display: inline-block;
		margin-top: var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-ink);
		text-decoration: none;
		font-weight: 600;
	}
	.v-empty-back:hover { text-decoration: underline; }

	@media (max-width: 1100px) {
		.v-grid { grid-template-columns: repeat(3, 1fr); }
	}
	@media (max-width: 820px) {
		.v-hero { grid-template-columns: 1fr; }
		.v-grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 500px) {
		.v-grid { grid-template-columns: 1fr; }
	}
</style>
